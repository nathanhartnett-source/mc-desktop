  "productName": "Allhart AIOS",
  "version": "0.1.0",
  "identifier": "com.allhart.mc-desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Allhart AIOS",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
